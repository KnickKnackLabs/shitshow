#!/usr/bin/env bash

set -euo pipefail
umask 077

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source "$repo_root/lib/common.sh"

meeting_id="${1:-}"
token="${2:-}"
chunk_seconds="${3:-300}"
model="${4:-qwen3-asr-0.6b}"
prompt_file="${SHITSHOW_JOB_PROMPT_FILE:-}"

shitshow_validate_meeting_id "$meeting_id"
[[ "$token" =~ ^[0-9a-f]{32}$ ]] || shitshow_die "invalid transcription job token"
dir="$(shitshow_require_meeting "$meeting_id")"
state="$dir/transcribe-job.json"
[ ! -L "$state" ] || shitshow_die "transcription job state must not be a symlink"

write_state() {
  local status="$1"
  local exit_code="${2:-}"
  local finished_at="${3:-}"
  local temporary
  temporary="$dir/.transcribe-job.json.$$.$(shitshow_random_hex 2)"
  jq -n \
    --arg status "$status" \
    --arg token "$token" \
    --arg started_at "$started_at" \
    --arg finished_at "$finished_at" \
    --arg exit_code "$exit_code" \
    --argjson pid "$$" \
    '{schema_version:1,status:$status,pid:$pid,token:$token,started_at:$started_at,finished_at:(if $finished_at == "" then null else $finished_at end),exit_code:(if $exit_code == "" then null else ($exit_code|tonumber) end)}' \
    > "$temporary"
  chmod 600 "$temporary"
  mv "$temporary" "$state"
}

started_at="$(shitshow_iso_now)"
write_state running

args=(transcribe "$meeting_id" --chunk-seconds "$chunk_seconds" --model "$model")
if [ -n "$prompt_file" ]; then
  args+=(--prompt-file "$prompt_file")
fi

child=""
stopping=false
# shellcheck disable=SC2329 # Invoked by the signal trap below.
stop_child() {
  stopping=true
  if [[ "$child" =~ ^[1-9][0-9]*$ ]] && kill -0 "$child" 2>/dev/null; then
    if ! kill -TERM "$child" 2>/dev/null; then
      printf 'Could not signal transcription child %s\n' "$child" >&2
    fi
  fi
}
trap stop_child TERM INT

(
  cd "$repo_root"
  SHITSHOW_CALLER_PWD="/" mise run "${args[@]}"
) &
child=$!

set +e
wait "$child"
status=$?
set -e

if [ "$stopping" = true ] || [ "$status" -eq 130 ] || [ "$status" -eq 143 ]; then
  write_state paused "$status" "$(shitshow_iso_now)"
  exit 0
elif [ "$status" -eq 0 ]; then
  write_state complete 0 "$(shitshow_iso_now)"
  exit 0
else
  write_state failed "$status" "$(shitshow_iso_now)"
  exit "$status"
fi

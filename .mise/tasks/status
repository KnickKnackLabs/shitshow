#!/usr/bin/env bash
#MISE description="Show recording, transcription, and review state"
#USAGE arg "<meeting_id>" help="Managed meeting identifier"
#USAGE flag "--json" default=#false help="Print machine-readable JSON"
#USAGE example "shitshow status 20260716T145938Z-a1b2c3d4" header="Inspect meeting progress"
#USAGE example "shitshow status 20260716T145938Z-a1b2c3d4 --json" header="Inspect machine-readable status"

set -euo pipefail

exec "$MISE_CONFIG_ROOT/libexec/status" \
  "$usage_meeting_id" \
  "${usage_json:-false}"

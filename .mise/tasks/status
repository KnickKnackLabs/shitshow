#!/usr/bin/env bash
#MISE description="Show recording, transcription, and review state"
#USAGE arg "<meeting_id>" help="Managed meeting identifier"
#USAGE flag "--json" default=#false help="Print machine-readable JSON"
#USAGE example "shitshow status 20260716T145938Z-a1b2c3d4" header="Inspect meeting progress"
#USAGE example "shitshow status 20260716T145938Z-a1b2c3d4 --json" header="Inspect machine-readable status"

set -euo pipefail

source "$MISE_CONFIG_ROOT/lib/common.sh"
source "$MISE_CONFIG_ROOT/lib/transcription.sh"

meeting_id="$usage_meeting_id"
json="${usage_json:-false}"
dir="$(shitshow_require_meeting "$meeting_id")"
audio="$(shitshow_audio_path "$dir")"
expected="$(shitshow_expected_sha "$dir")"
actual="$(shitshow_sha256 "$audio")"
duration="$(jq -er '.duration_seconds' "$dir/meeting.json")"
bytes="$(shitshow_file_size "$audio")"
name="$(jq -r '.name // ""' "$dir/meeting.json")"

health=ok
checksum=ok
exit_status=0
if [ "$actual" != "$expected" ]; then
  health=error
  checksum=mismatch
  exit_status=3
fi

review_state="$dir/review-state.json"
shitshow_require_regular_file "$review_state" "review state"
review_cursor="$(jq -er '.cursor | select(type == "number" and . >= 0 and floor == .)' "$review_state" 2>/dev/null)" || \
  shitshow_die "invalid review state: $review_state"

chunk_count=0
chunk_seconds=0
model=""
complete=0
failed=0
transcription=not-started
job_state="$(shitshow_job_state "$dir")"
config_chunk_count=""
if config_chunk_count="$(shitshow_read_config "$dir" '.chunk_count' 2>/dev/null)"; then
  chunk_count="$config_chunk_count"
  chunk_seconds="$(shitshow_read_config "$dir" '.chunk_seconds')"
  model="$(shitshow_read_config "$dir" '.model')"
  complete="$(shitshow_marker_count "$dir" ok)"
  failed="$(shitshow_marker_count "$dir" failed)"
  if [ "$job_state" = running ]; then
    transcription=running
  elif [ "$job_state" = stale ]; then
    transcription=stale
    health=error
    exit_status=4
  elif [ "$complete" -eq "$chunk_count" ]; then
    transcription=complete
  elif [ "$failed" -gt 0 ]; then
    transcription=failed
  else
    transcription=paused
  fi
elif [ "$job_state" = running ]; then
  transcription=running
elif [ "$job_state" = stale ]; then
  transcription=stale
  health=error
  exit_status=4
fi

if [ "$review_cursor" -gt "$chunk_count" ] && [ "$chunk_count" -gt 0 ]; then
  health=error
  exit_status=5
fi

if [ "$json" = true ]; then
  jq -n \
    --arg health "$health" \
    --arg meeting_id "$meeting_id" \
    --arg name "$name" \
    --arg workspace "$dir" \
    --arg checksum "$checksum" \
    --arg expected_sha256 "$expected" \
    --arg actual_sha256 "$actual" \
    --arg transcription "$transcription" \
    --arg model "$model" \
    --argjson duration_seconds "$duration" \
    --argjson bytes "$bytes" \
    --argjson chunks_complete "$complete" \
    --argjson chunks_failed "$failed" \
    --argjson chunk_count "$chunk_count" \
    --argjson chunk_seconds "$chunk_seconds" \
    --argjson review_cursor "$review_cursor" \
    '{health:$health,meeting_id:$meeting_id,name:$name,workspace:$workspace,recording:{checksum:$checksum,expected_sha256:$expected_sha256,actual_sha256:$actual_sha256,duration_seconds:$duration_seconds,bytes:$bytes},transcription:{status:$transcription,model:(if $model == "" then null else $model end),chunks_complete:$chunks_complete,chunks_failed:$chunks_failed,chunk_count:$chunk_count,chunk_seconds:$chunk_seconds},review:{cursor:$review_cursor,total:$chunk_count}}'
else
  printf 'meeting: %s\n' "$meeting_id"
  if [ -n "$name" ]; then
    printf 'name: %s\n' "$name"
  fi
  printf 'health: %s\n' "$health"
  printf 'checksum: %s\n' "$checksum"
  printf 'duration: %.1f seconds\n' "$duration"
  printf 'audio bytes: %s\n' "$bytes"
  printf 'transcription: %s\n' "$transcription"
  if [ "$chunk_count" -gt 0 ]; then
    printf 'chunks: %s/%s complete, %s failed, %ss each\n' \
      "$complete" "$chunk_count" "$failed" "$chunk_seconds"
    printf 'model: %s\n' "$model"
    printf 'review: %s/%s\n' "$review_cursor" "$chunk_count"
  else
    printf 'review: %s\n' "$review_cursor"
  fi
  printf 'workspace: %s\n' "$dir"
fi

exit "$exit_status"

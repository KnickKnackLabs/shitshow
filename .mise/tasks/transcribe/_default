#!/usr/bin/env bash
#MISE description="Transcribe a managed meeting locally in resumable chunks"
#USAGE arg "<meeting_id>" help="Managed meeting identifier"
#USAGE flag "--chunk-seconds <seconds>" default="300" help="Chunk length in seconds"
#USAGE flag "--model <model>" default="qwen3-asr-0.6b" help="Local Qwen ASR model"
#USAGE flag "--prompt-file <path>" default="" help="Optional private ASR prompt to import"
#USAGE example "shitshow transcribe 20260716T145938Z-a1b2c3d4" header="Transcribe with safe defaults"
#USAGE example "shitshow transcribe 20260716T145938Z-a1b2c3d4 --prompt-file ./asr-prompt.txt" header="Import a private ASR prompt"

set -euo pipefail
umask 077

source "$MISE_CONFIG_ROOT/lib/common.sh"
source "$MISE_CONFIG_ROOT/lib/transcription.sh"

meeting_id="$usage_meeting_id"
chunk_seconds="$usage_chunk_seconds"
model="$usage_model"
prompt_file="${usage_prompt_file:-}"
caller_dir="${SHITSHOW_CALLER_PWD:-$PWD}"
monkeys_bin="${SHITSHOW_MONKEYS_BIN:-monkeys}"

[[ "$chunk_seconds" =~ ^[1-9][0-9]*$ ]] || ss_die "chunk seconds must be a positive integer"
case "$model" in
  qwen3-asr-0.6b|qwen3-asr-1.7b) ;;
  *) ss_die "unsupported model: $model" ;;
esac
ss_require_command ffmpeg
ss_require_command ffprobe
ss_require_command jq
command -v "$monkeys_bin" >/dev/null 2>&1 || ss_die "monkeys is required"

dir="$(ss_require_meeting "$meeting_id")"
audio="$(ss_audio_path "$dir")"
ss_verify_recording "$dir" >/dev/null

for managed_dir in chunks transcripts; do
  path="$dir/$managed_dir"
  [ ! -L "$path" ] || ss_die "$managed_dir directory must not be a symlink"
  if [ ! -e "$path" ]; then
    mkdir -m 700 "$path"
  fi
  ss_assert_private_dir "$path" "$managed_dir directory"
done

has_artifacts=false
for artifact in "$dir"/chunks/* "$dir"/transcripts/*; do
  if [ -e "$artifact" ] || [ -L "$artifact" ]; then
    has_artifacts=true
    break
  fi
done

managed_prompt="$dir/asr-prompt.txt"
prompt_sha=""
if [ -n "$prompt_file" ]; then
  if [[ "$prompt_file" != /* ]]; then
    prompt_file="$caller_dir/$prompt_file"
  fi
  [ -f "$prompt_file" ] && [ -r "$prompt_file" ] || ss_die "prompt file not found or unreadable: $prompt_file"
  provided_prompt_sha="$(ss_sha256 "$prompt_file")"
  if ! old_prompt_sha="$(ss_read_config "$dir" '.prompt_sha // ""' 2>/dev/null)"; then
    old_prompt_sha=""
  fi
  if [ "$has_artifacts" = true ] && [ "$provided_prompt_sha" != "$old_prompt_sha" ]; then
    ss_die "cannot change prompt after transcription artifacts exist"
  fi
  prompt_tmp="$dir/.asr-prompt.txt.$$.$(ss_random_hex 2)"
  cp -- "$prompt_file" "$prompt_tmp"
  chmod 600 "$prompt_tmp"
  mv "$prompt_tmp" "$managed_prompt"
  prompt_sha="$provided_prompt_sha"
elif [ -e "$managed_prompt" ] || [ -L "$managed_prompt" ]; then
  ss_require_regular_file "$managed_prompt" "managed ASR prompt"
  prompt_sha="$(ss_sha256 "$managed_prompt")"
fi

if [ -f "$dir/transcribe-config.json" ]; then
  if ! old_chunk_seconds="$(ss_read_config "$dir" '.chunk_seconds' 2>/dev/null)"; then
    old_chunk_seconds=""
  fi
  if ! old_model="$(ss_read_config "$dir" '.model' 2>/dev/null)"; then
    old_model=""
  fi
  if ! old_prompt_sha="$(ss_read_config "$dir" '.prompt_sha // ""' 2>/dev/null)"; then
    old_prompt_sha=""
  fi
  if [ "$has_artifacts" = true ] && \
      { [ "$old_chunk_seconds" != "$chunk_seconds" ] || [ "$old_model" != "$model" ] || [ "$old_prompt_sha" != "$prompt_sha" ]; }; then
    ss_die "cannot change chunk size, model, or prompt after transcription artifacts exist"
  fi
fi

lock="$dir/.transcribe.lock"
ss_acquire_lock "$lock" "transcription"
cleanup() {
  ss_release_lock "$lock"
}
trap cleanup EXIT
trap 'exit 130' INT
trap 'exit 143' TERM

duration="$(ss_duration "$audio")"
total="$(ss_total_seconds "$duration")"
chunk_count="$(ss_chunk_count "$total" "$chunk_seconds")"
config_tmp="$dir/.transcribe-config.json.$$.$(ss_random_hex 2)"
jq -n \
  --arg model "$model" \
  --arg prompt_sha "$prompt_sha" \
  --argjson duration_seconds "$duration" \
  --argjson total_seconds "$total" \
  --argjson chunk_seconds "$chunk_seconds" \
  --argjson chunk_count "$chunk_count" \
  '{schema_version:1,duration_seconds:$duration_seconds,total_seconds:$total_seconds,chunk_seconds:$chunk_seconds,chunk_count:$chunk_count,model:$model,prompt_sha:$prompt_sha}' \
  > "$config_tmp"
chmod 600 "$config_tmp"
mv "$config_tmp" "$dir/transcribe-config.json"

log="$dir/transcribe.log"
if [ ! -e "$log" ]; then
  : > "$log"
  chmod 600 "$log"
else
  ss_require_regular_file "$log" "transcription log"
fi
printf '[%s] run pid=%s model=%s chunk_seconds=%s chunks=%s\n' \
  "$(ss_iso_now)" "$$" "$model" "$chunk_seconds" "$chunk_count" >> "$log"

asr_command=("$monkeys_bin" hear --no-cache --model "$model")
if [ -s "$managed_prompt" ]; then
  asr_command+=(--prompt-file "$managed_prompt")
  printf '[%s] using managed prompt sha256=%s\n' "$(ss_iso_now)" "$prompt_sha" >> "$log"
fi

ss_write_progress "$dir" "$total" "$chunk_seconds" "$chunk_count"

for ((i = 0; i < chunk_count; i++)); do
  id="$(printf '%03d' "$i")"
  start=$((i * chunk_seconds))
  seconds="$(ss_chunk_duration "$i" "$total" "$chunk_seconds")"
  chunk="$dir/chunks/chunk-${id}.wav"
  transcript="$dir/transcripts/chunk-${id}.txt"
  ok_marker="$dir/transcripts/chunk-${id}.ok"
  failed_marker="$dir/transcripts/chunk-${id}.failed"

  for managed_file in "$chunk" "$transcript" "$ok_marker" "$failed_marker"; do
    [ ! -L "$managed_file" ] || ss_die "managed transcription artifact must not be a symlink: $managed_file"
  done

  if [ -f "$ok_marker" ] && [ -f "$transcript" ]; then
    printf '[%s] reusing completed chunk %s\n' "$(ss_iso_now)" "$id" >> "$log"
    continue
  fi

  if [ ! -s "$chunk" ]; then
    printf '[%s] extracting chunk %s start=%s seconds=%s\n' \
      "$(ss_iso_now)" "$id" "$start" "$seconds" >> "$log"
    chunk_tmp="$dir/chunks/.chunk-${id}.$$.$(ss_random_hex 2).wav"
    ffmpeg -hide_banner -loglevel error -y \
      -ss "$start" -t "$seconds" -i "$audio" \
      -ar 16000 -ac 1 -c:a pcm_s16le "$chunk_tmp" >> "$log" 2>&1
    chmod 600 "$chunk_tmp"
    mv "$chunk_tmp" "$chunk"
  fi

  printf '[%s] transcribing chunk %s\n' "$(ss_iso_now)" "$id" >> "$log"
  transcript_tmp="$dir/transcripts/.chunk-${id}.$$.$(ss_random_hex 2).txt"
  rm -f "$failed_marker" "$transcript_tmp"

  if "${asr_command[@]}" "$chunk" > "$transcript_tmp" 2>> "$log"; then
    chmod 600 "$transcript_tmp"
    mv "$transcript_tmp" "$transcript"
    : > "$ok_marker"
    chmod 600 "$ok_marker"
  else
    status=$?
    rm -f "$transcript_tmp" "$ok_marker"
    printf '%s\n' "$status" > "$failed_marker"
    chmod 600 "$failed_marker"
    ss_write_progress "$dir" "$total" "$chunk_seconds" "$chunk_count"
    printf '[%s] failed chunk %s exit=%s\n' "$(ss_iso_now)" "$id" "$status" >> "$log"
    exit "$status"
  fi

  ss_write_progress "$dir" "$total" "$chunk_seconds" "$chunk_count"
done

printf '[%s] complete\n' "$(ss_iso_now)" >> "$log"
printf 'meeting: %s\nstatus: complete\nchunks: %s\ntranscript: %s\n' \
  "$meeting_id" "$chunk_count" "$dir/transcript.combined.txt"
